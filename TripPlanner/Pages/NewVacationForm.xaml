<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
             xmlns:model="clr-namespace:TripPlanner.PageModels"
             xmlns:controls="clr-namespace:TripPlanner.Controls"
             x:Class="TripPlanner.Pages.NewVacationPage"
             x:DataType="model:NewVacationPageModel"
             Title="Create Vacation">

    <!--https://github.com/SyncfusionExamples/.NET-MAUI-Data-form-SQLite/tree/master/DataFormMAUI-->
    <StackLayout>
        <controls:ThemeAwareDataForm DataObject="{Binding Vacation}" 
                                     LayoutType="TextInputLayout"
                                     ValidationMode="PropertyChanged"
                                     CommitMode="PropertyChanged"
                                     x:Name="dataForm"/>

        <buttons:SfButton Text="Save"
                          Clicked="OnSaveClicked" />
    </StackLayout>

</ContentPage>